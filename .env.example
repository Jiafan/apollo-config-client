# Apollo Config Service 地址（docker-quick-start 默认 http://localhost:8080，不是 Portal 的 8070）
APOLLO_CONFIG_URL=http://localhost:8080

# 应用 AppId（在 Apollo Portal 创建应用时记录）
APOLLO_APP_ID=flask-apollo-lab

# 集群（通常 default）
APOLLO_CLUSTER=default

# 环境名（与 Apollo 的环境/集群隔离 dev/test/prod 对应）
APOLLO_ENV=DEV

# 订阅的 namespace，逗号分隔
APOLLO_NAMESPACES=application,database,ldap

# 访问密钥（可选）：Apollo 1.6+ 开启后必填；留空走匿名访问
# APOLLO_ACCESS_KEY_SECRET=38fdae497a324263a5ad81aa387deee3

# 本地缓存目录
APOLLO_CACHE_DIR=.apollo_cache

# Oracle Instant Client 路径（仅 Oracle 11g 需要 thick 模式；>=12.1 可省略）
# ORACLE_INSTANT_CLIENT=/opt/lib/instantclient-basiclite-arm-23.26.1.0.0
